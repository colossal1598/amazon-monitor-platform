# Copy to .env in this directory and adjust. docker compose reads it automatically.

# --- Postgres ---
POSTGRES_USER=scraper
POSTGRES_PASSWORD=scraper
POSTGRES_DB=scraper
POSTGRES_PORT=5432
N8N_DB=n8n

# --- Auth ---
# API_TOKEN: shared secret the worker and n8n send as X-API-Token.
API_TOKEN=change-me-to-a-long-random-token
# Basic-auth for the admin UI + its API, and for the n8n editor.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# --- Ports ---
BACKEND_PORT=8000
N8N_PORT=5678
WA_PORT=3001

# --- Scheduling defaults (a group may override via interval_minutes) ---
SHORT_INTERVAL_MINUTES=4
LONG_INTERVAL_MINUTES=60

# --- Worker ---
# Leave PROXY_URL empty to use the host IP (set it for residential/mobile proxies).
PROXY_URL=
HEADLESS=true
POLL_INTERVAL_SECONDS=5
MAX_REQUESTS_PER_MINUTE=10
WORKER_ID=docker-worker-1

# --- WhatsApp (wa-server) ---
# In-stack (vendored) wa-server uses the service name. If you instead run wa-server
# on the host (e.g. the mobile-IP PC), set WA_API_URL=http://host.docker.internal:3001.
WA_API_URL=http://wa-server:3001
WA_API_KEY=
# Default WhatsApp recipient JID when a group has no notify_channel (e.g. 123...@g.us).
WA_GROUP_ID=
# Path to the vendored wa-server folder for the optional --profile whatsapp build.
WA_SERVER_PATH=../wa-server

# --- Misc ---
LOG_LEVEL=INFO
TZ=Asia/Jerusalem
# Set true to auto-create a demo SERP group on first boot.
SEED_DEMO_GROUP=false

# --- Optional: push pending alerts to an n8n webhook on run completion ---
# (Leave empty to use the poll-based notifier workflow instead.)
# SELECTOR_PROFILE_JSON can hotfix selectors without a DB write (JSON string).
SELECTOR_PROFILE_JSON=
