# Copy to .env in this directory and adjust. docker compose reads it automatically.
#
# Windows client setup guide: WINDOWS_CLIENT_SETUP.md

# --- Postgres ---
POSTGRES_USER=scraper
POSTGRES_PASSWORD=scraper
POSTGRES_DB=scraper
POSTGRES_PORT=5432
# n8n uses database "n8n" on the same Postgres server (see initdb/01-create-n8n-db.sql).

# --- Auth ---
# API_TOKEN: shared secret the worker and n8n send as X-API-Token. Change before exposing via Tailscale.
API_TOKEN=change-me-to-a-long-random-token
# Basic-auth for the admin UI and n8n editor.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# --- Ports ---
# BACKEND_PORT: Admin UI + API. Use 8443 if exposing via Tailscale Funnel (only 443/8443/10000 work).
BACKEND_PORT=8000
# BACKEND_PORT=8443
N8N_PORT=5678
WA_PORT=3001

# --- Worker ---
# Leave PROXY_URL empty on a client PC to use the machine's residential/mobile IP.
PROXY_URL=
HEADLESS=true
POLL_INTERVAL_SECONDS=5
MAX_REQUESTS_PER_MINUTE=10
WORKER_ID=docker-worker-1

# --- WhatsApp (wa-server) ---
# In-stack: http://wa-server:3001  |  Host on Windows: http://host.docker.internal:3001
WA_API_URL=http://wa-server:3001
WA_API_KEY=
# Default WhatsApp JID when a group has no notify_channel (e.g. 123...@g.us).
WA_GROUP_ID=
WA_SERVER_PATH=../wa-server

# --- n8n webhook ---
# Production URL from the job-processor Webhook node in n8n (see WINDOWS_CLIENT_SETUP.md).
# Inside Docker use the n8n service hostname (not localhost):
# N8N_JOB_DONE_WEBHOOK_URL=http://n8n:5678/webhook/job-done
N8N_JOB_DONE_WEBHOOK_URL=

# --- Misc ---
LOG_LEVEL=INFO
TZ=Asia/Jerusalem
# true = create a harmless demo SERP group on first boot (smoke test).
SEED_DEMO_GROUP=false

# --- Optional: hotfix selectors without a DB write (JSON string) ---
SELECTOR_PROFILE_JSON=
